<doc 
    xmlns="https://hyperview.org/hyperview"
    xmlns:navigation="https://hyperview.org/navigation"
    >
    <screen>
        <styles>
            {% include "hv/styles/index.style.xml" %}
        </styles>
        <body>

            {% block header %}
            <header style="header flex-header">
                <text>MySaveMoneyLife</text>
            </header>
            {% endblock header %}

            {% block content %}{% endblock %}   

            <navigation:bottom-tab-bar
                navigation:navigator="tabs-navigator"
            >
                <navigation:bottom-tab-bar-item navigation:route="today">
                    <view style="btn btn-tab">
                        <text style="text-dark text-large text-center">Today</text>
                    </view>
                </navigation:bottom-tab-bar-item>

                <navigation:bottom-tab-bar-item navigation:route="buckets">
                    <view style="btn btn-tab">
                        <text style="text-dark text-large text-center">Buckets</text>
                    </view>
                </navigation:bottom-tab-bar-item>

            </navigation:bottom-tab-bar>

        </body>
  </screen>
</doc>