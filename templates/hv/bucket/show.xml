{% extends "hv/layout.xml" %}

{% block header %}
<header style="header flex-header">
    <view style="header-placeholder" action="back">
        {% include "hv/svg/back.xml" %}
    </view>
    <text style="heading text-dark text-center">Top Up</text>
    <view style="header-placeholder" action="reload" href="/hv/top-up/{{ bucket.top_up.top_up_id }}/edit">
        {% include "hv/svg/edit.xml" %}
    </view>
</header>
{% endblock header %}

{% block content %}
<list style="container">
    <item style="card margin-bottom">
        <text style="text-dark text-large">Bucket: {{ bucket.name }}</text>
        <text style="text-dark text-large">Month: {{ bucket.top_up.month_start }}</text>
        <text style="text-dark text-large">Starting Amount: {{ bucket.top_up.start_amount }}</text>
        <text style="text-dark text-large">Amount Remaining: {{ bucket.top_up.end_amount if bucket.top_up.end_amount else 0 }}</text>
    </item>

    <item id="top-up-purchases">
        <behavior 
            href="/hv/buckets/{{ bucket.bucket_id }}?content=list" 
            trigger="load" 
            target="top-up-purchases" 
            action="replace" />
        <text style="card text-large text-dark">Loading...</text>
    </item>
    
</list>
{% endblock content%}