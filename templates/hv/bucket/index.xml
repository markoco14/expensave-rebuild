{% extends "hv/layout.xml" %}

{% block header %}
<header style="header">
	<text style="heading text-dark text-center">Buckets</text>
</header>
{% endblock header %}

{% block content %}
<view style="container column">
	<behavior trigger="on-event" event-name="top-up-updated" action="reload" href="/hv/buckets"/>

	<text style="heading text-dark text-center">{{ current_month.strftime("%B %Y") }}</text>

	{% for bucket in buckets %}
	<view style="card">
		<behavior action="push" href="/hv/top-up/{{ bucket.top_up.top_up_id }}"/>
		<text style="text-dark text-large text-center">{{ bucket.name }}</text>
		<text style="text-dark balance text-center">Balance: ${{ bucket.top_up.end_amount if bucket.top_up.end_amount else 0 }}</text>
	</view>
	{% endfor %}

</view>

{% endblock content %}
